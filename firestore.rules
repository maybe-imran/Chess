rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard zero-trust verification primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------
    // USER PROFILES SECTION (/users/{userId})
    // -------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn(); // Hardened: only signed in users can read public user profiles
      allow create: if isSignedIn() && request.auth.uid == userId 
        && isValidUserProfile(incoming()) 
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && request.auth.uid == userId 
        && isValidUserProfile(incoming()) 
        && incoming().createdAt == existing().createdAt;
      
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 50
        && data.createdAt is int
        && data.statsPlaceholder is map
        && data.statsPlaceholder.gamesPlayed is int && data.statsPlaceholder.gamesPlayed >= 0
        && data.statsPlaceholder.gamesWon is int && data.statsPlaceholder.gamesWon >= 0
        && data.statsPlaceholder.gamesLost is int && data.statsPlaceholder.gamesLost >= 0
        && data.statsPlaceholder.gamesDrawn is int && data.statsPlaceholder.gamesDrawn >= 0
        && data.keys().hasAll(['uid', 'username', 'createdAt', 'statsPlaceholder'])
        && data.keys().size() == 4;
    }

    // -------------------------------------------------------------
    // MATCHMAKING QUEUE SECTION (/matchmaking_queue/{userId})
    // -------------------------------------------------------------
    match /matchmaking_queue/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource == null || resource.data.status == 'waiting' || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && request.auth.uid == userId 
        && isValidMatchmakingQueue(incoming()) 
        && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
        // Action A: Self cancel or profile state adjustment
        (request.auth.uid == userId && isValidMatchmakingQueue(incoming())) ||
        // Action B: Adversarial pairing transition (Player matches with the ticket holder)
        (existing().status == 'waiting' && incoming().status == 'matched' 
         && incoming().matchedWith == request.auth.uid 
         && incoming().username == existing().username 
         && incoming().createdAt == existing().createdAt)
      );

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    function isValidMatchmakingQueue(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.username is string && data.username.size() >= 3 && data.username.size() <= 50
        && data.status is string && (data.status == 'waiting' || data.status == 'matched')
        && data.createdAt is int
        && (data.status == 'waiting' || (
             data.matchedWith is string && data.matchedWith.size() <= 128
             && data.matchedWithName is string && data.matchedWithName.size() <= 50
             && data.roomId is string && data.roomId.size() == 6
             && data.assignedColor is string && (data.assignedColor == 'w' || data.assignedColor == 'b')
           ));
    }

    // -------------------------------------------------------------
    // GAME ROOMS SYNC SECTION (/rooms/{roomId})
    // -------------------------------------------------------------
    match /rooms/{roomId} {
      allow read: if isValidRoomId(roomId) && (
        // Option A: Room is awaiting a player (needs read access to check exists/has space before joining)
        (resource == null || resource.data.status == 'waiting') ||
        // Option B: Legitimate room participant
        (request.auth != null && (request.auth.uid == resource.data.whitePlayerId || request.auth.uid == resource.data.blackPlayerId))
      );
      
      allow create: if isValidRoomId(roomId) && isSignedIn() && isValidRoom(incoming()) && (
        incoming().creatorId == request.auth.uid &&
        (incoming().whitePlayerId == request.auth.uid || incoming().blackPlayerId == request.auth.uid)
      );
      
      allow update: if isValidRoomId(roomId) && isSignedIn() && isValidRoom(incoming()) && (
        // Action 1: Authenticated user joins the vacant slot (must be setting their uid as the player)
        (existing().status == 'waiting' && incoming().status == 'ready' && 
         (
           (existing().whitePlayerId == null && incoming().whitePlayerId == request.auth.uid && incoming().blackPlayerId == existing().blackPlayerId) ||
           (existing().blackPlayerId == null && incoming().blackPlayerId == request.auth.uid && incoming().whitePlayerId == existing().whitePlayerId)
         ) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['whitePlayerId', 'whitePlayerName', 'blackPlayerId', 'blackPlayerName', 'status', 'whiteLastActive', 'blackLastActive', 'creatorId'])
        ) ||
        // Action 2: Play chess piece move (Updates FEN state)
        // Strictly enforces that the player corresponds to the current turn before the move
        (existing().status == 'ready' && incoming().status == 'ready' && 
         ((existing().currentTurn == 'w' && request.auth.uid == existing().whitePlayerId) ||
          (existing().currentTurn == 'b' && request.auth.uid == existing().blackPlayerId)) &&
         incoming().moveCount == existing().moveCount + 1 &&
         incoming().diff(existing()).affectedKeys().hasOnly(['fen', 'moveCount', 'currentTurn', 'lastMove', 'history', 'whiteLastActive', 'blackLastActive'])
        ) ||
        // Action 3: Multi-client passive heartbeats updates
        ((request.auth.uid == existing().whitePlayerId && incoming().diff(existing()).affectedKeys().hasOnly(['whiteLastActive'])) || 
         (request.auth.uid == existing().blackPlayerId && incoming().diff(existing()).affectedKeys().hasOnly(['blackLastActive'])) ||
         (request.auth.uid == existing().whitePlayerId && request.auth.uid == existing().blackPlayerId && incoming().diff(existing()).affectedKeys().hasOnly(['whiteLastActive', 'blackLastActive']))
        ) ||
        // Action 4: Conclude game via resignation or draw
        (existing().status == 'ready' && incoming().status == 'gameover' && 
         (request.auth.uid == existing().whitePlayerId || request.auth.uid == existing().blackPlayerId) &&
         incoming().resignedColor != null && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'resignedColor'])
        ) ||
        // Action 5: Sync chat appends
        (incoming().messages != null && 
         (request.auth.uid == existing().whitePlayerId || request.auth.uid == existing().blackPlayerId) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'whiteLastActive', 'blackLastActive'])
        ) ||
        // Action 6: Reset / restart game
        ((request.auth.uid == existing().whitePlayerId || request.auth.uid == existing().blackPlayerId) &&
         incoming().status == 'ready' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['fen', 'moveCount', 'currentTurn', 'lastMove', 'history', 'whiteLastActive', 'blackLastActive', 'resignedColor', 'status', 'messages'])
        )
      );

      allow delete: if false; // Room cleanup is managed outside client scopes
    }

    function isValidRoomId(id) {
      return id is string && id.size() == 6 && id.matches('^[A-Z0-9]+$');
    }

    function isValidRoom(data) {
      return data.roomId is string && data.roomId.size() == 6
        && data.fen is string && data.fen.size() >= 15 && data.fen.size() <= 120
        && (data.whitePlayerId == null || (data.whitePlayerId is string && data.whitePlayerId.size() <= 128))
        && (data.blackPlayerId == null || (data.blackPlayerId is string && data.blackPlayerId.size() <= 128))
        && (data.whitePlayerName == null || (data.whitePlayerName is string && data.whitePlayerName.size() <= 50))
        && (data.blackPlayerName == null || (data.blackPlayerName is string && data.blackPlayerName.size() <= 50))
        && data.whiteLastActive is int
        && data.blackLastActive is int
        && data.status is string && (data.status == 'waiting' || data.status == 'ready' || data.status == 'gameover')
        && data.moveCount is int && data.moveCount >= 0
        && data.creatorId is string && data.creatorId.size() <= 128
        && data.currentTurn is string && (data.currentTurn == 'w' || data.currentTurn == 'b')
        && (data.lastMove == null || (
             data.lastMove.from is string && data.lastMove.from.size() == 2
             && data.lastMove.to is string && data.lastMove.to.size() == 2
             && data.lastMove.timestamp is int
           ))
        && (data.resignedColor == null || (data.resignedColor is string && (data.resignedColor == 'w' || data.resignedColor == 'b')))
        && (data.history == null || data.history is list)
        && (data.messages == null || (data.messages is list && data.messages.size() <= 1000));
    }
  }
}
